CREATE TABLE Categorie (
    id_categoria INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE Spese (
    id_spesa INT AUTO_INCREMENT PRIMARY KEY,
    data_spesa DATE NOT NULL,
    importo DECIMAL(10,2) NOT NULL,
    descrizione VARCHAR(255),
    id_categoria INT,
    CONSTRAINT chk_importo_positivo CHECK (importo > 0),
    FOREIGN KEY (id_categoria) REFERENCES Categorie(id_categoria)
);

CREATE TABLE Budget (
    mese VARCHAR(7) NOT NULL, -- Formato YYYY-MM
    id_categoria INT,
    importo_limite DECIMAL(10,2) NOT NULL,
    PRIMARY KEY (mese, id_categoria),
    CONSTRAINT chk_budget_positivo CHECK (importo_limite > 0),
    FOREIGN KEY (id_categoria) REFERENCES Categorie(id_categoria)
);

